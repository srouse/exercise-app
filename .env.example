# Postgres connection string (from Vercel Marketplace e.g. Neon, or any Postgres provider).
# On Vercel, add a Postgres integration in Storage/Marketplace to get NETLIFY_DATABASE_URL.
NETLIFY_DATABASE_URL=

# Auth0 (Regular Web Application). Create the app in Auth0 Dashboard, then set:
# AUTH0_DOMAIN = your tenant domain (e.g. your-tenant.auth0.com)
# AUTH0_CLIENT_ID = Application Client ID
# AUTH0_CLIENT_SECRET = Application Client Secret
# AUTH0_SECRET = long random string (e.g. openssl rand -hex 32)
# APP_BASE_URL = http://localhost:3000 (or your production URL)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

